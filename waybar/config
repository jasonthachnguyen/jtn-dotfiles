{
    "name": "enten-DP",
    "position": "top",
    "height": 40,
    "reload_style_on_change": true,

    "margin": 0,
    "margin-left": 17,
    "margin-right": 17,
    "spacing": 0,

    "include": [
        "~/.config/waybar/hyprland-modules.json",
        "~/.config/waybar/music-modules.json",
        "~/.config/waybar/custom-modules.json",
        "~/.config/waybar/standard-modules.json",
    ],

    "group/app-drawer": {
        "orientation": "horizontal",
        "modules": [
            "hyprland/window",
            "custom/divider",
            "wlr/taskbar",
        ],
        "drawer": {
            "transition-duration": 300,
            "transition-left-to-right": true,
            "children-class": "drawer-child",
        },
    },

    "group/music-modules":{
        "orientation": "horizontal",
        "modules": [
            "mpd",
            "cava",
        ],
    },

    "group/sysinfo": {
        "orientation": "horizontal",
        "modules": [
            "cpu",
            "memory",
            "keyboard-state",
        ],
    },

    "modules-left": [
        "hyprland/submap",
        "hyprland/workspaces",
        "group/app-drawer",
        ],

    "modules-center": [
        "pulseaudio",
        "group/music-modules",
        ],

    "modules-right": [
        "bluetooth",
        "group/sysinfo",
        "clock",
        ],
}
